# Groq API Key (required)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_secondary_groq_api_key_here  # Optional: Fallback key for rate limits
GROQ_API_KEY_3=your_tertiary_groq_api_key_here   # Optional: Fallback key for rate limits

# Server
PORT=8000
ENVIRONMENT=development

# Rate Limiting (analyses per hour per IP)
RATE_LIMIT=10/hour

# CORS — comma-separated origins (* for all)
ALLOWED_ORIGINS=*

# Database
DATABASE_PATH=sume_ai.db
