{
  "version": 2,
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/static/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/static/robots.txt" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
